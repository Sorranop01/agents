{
  "organization": {
    "name": "MCP Code Development Organization",
    "version": "1.0.0",
    "structure": "hierarchical",
    "levels": 3
  },
  "agents": {
    "cto": {
      "id": "cto-agent",
      "name": "CTO Agent",
      "level": 1,
      "type": "executive",
      "role": "Chief Technology Officer",
      "responsibilities": [
        "Define technology strategy",
        "Receive and analyze user requirements",
        "Allocate resources across departments",
        "Make final architectural decisions",
        "Approve deliverables before delivery"
