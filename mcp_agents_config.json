  "workflows": {
    "standard_project": {
      "phases": [
        {
          "name": "Initiation",
          "steps": [
            "User submits requirements to CTO",
            "CTO analyzes and creates technical roadmap",
            "CTO identifies required departments"
          ]
        },
        {
          "name": "Planning",
          "steps": [
            "CTO assigns tasks to Department Heads",
            "Department Heads analyze and plan",
            "Department Heads report plans to CTO",
            "CTO approves plans"
          ]
        },
        {
          "name": "Execution",
          "steps": [
            "Department Heads assign tasks to Workers",
            "Workers execute tasks",
            "Workers report progress to Department Heads",
            "Department Heads provide guidance"
          ]
        },
        {
          "name": "Quality Assurance",
          "steps": [
            "Workers submit work to Department Heads",
            "Department Heads review and send to QA",
            "QA performs testing",
            "Issues are sent back for fixes if needed"
          ]
        },
        {
          "name": "Delivery",
          "steps": [
            "Department Heads report completion to CTO",
            "CTO reviews and approves final deliverable",
            "CTO delivers to User",
            "Project closed"
          ]
        }
      ]
    }
  },
  "communication_protocols": {
    "task_assignment": {
      "template": {
        "from": "sender_id",
        "to": "receiver_id",
        "priority": "high|medium|low",
        "deadline": "ISO8601_datetime",
        "task_description": "string",
        "acceptance_criteria": ["string"],
        "dependencies": ["task_id"]
      }
    },
    "progress_report": {
      "template": {
        "from": "sender_id",
        "to": "receiver_id",
        "status": "in_progress|complete|blocked",
        "completed": ["string"],
        "in_progress": ["string"],
        "blockers": ["string"],
        "next_steps": ["string"]
      }
    },
    "completion_report": {
      "template": {
        "from": "sender_id",
        "to": "receiver_id",
        "task_id": "string",
        "deliverables": ["string"],
        "test_results": "object",
        "documentation": "string"
      }
    }
  },
