        "direct_reports": ["frontend-head", "backend-head", "devops-head", "qa-head", "pm-head"],
        "communication_protocol": "direct"
      },
      "kpis": {
        "project_completion_rate": 0.95,
        "user_satisfaction": 4.5,
        "architecture_accuracy": 0.90
      }
