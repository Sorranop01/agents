# Hierarchical Agent Workflow - Mermaid Diagrams
# These diagrams can be rendered using Mermaid.js

# =============================================================================
# 1. TASK STATE MACHINE DIAGRAM
# =============================================================================

stateDiagram-v2
    [*] --> DRAFT : Create Task
    
    DRAFT --> PENDING : Submit
    DRAFT --> CANCELLED : Cancel
    
    PENDING --> ASSIGNED : Assign
    PENDING --> CANCELLED : Cancel
    
    ASSIGNED --> IN_PROGRESS : Start
    ASSIGNED --> REJECTED : Reject Assignment
    
    IN_PROGRESS --> REVIEWING : Submit
    IN_PROGRESS --> BLOCKED : Block
    IN_PROGRESS --> ERROR : Error
    IN_PROGRESS --> TIMEOUT : Timeout
    
    BLOCKED --> IN_PROGRESS : Unblock
    BLOCKED --> ERROR : Unrecoverable
    BLOCKED --> CANCELLED : Cancel
    
    REVIEWING --> APPROVED : Approve
    REVIEWING --> REJECTED : Reject
    
    APPROVED --> CLOSED : Close
    APPROVED --> ERROR : Post-approval Error
    
    REJECTED --> IN_PROGRESS : Rework
    REJECTED --> CANCELLED : Cancel
    
    COMPLETED --> CLOSED : Close
    
    CLOSED --> ARCHIVED : Archive
    
    ERROR --> IN_PROGRESS : Retry
    ERROR --> CANCELLED : Cancel
    
    TIMEOUT --> IN_PROGRESS : Resume
    TIMEOUT --> CANCELLED : Cancel
    
    CANCELLED --> ARCHIVED : Archive
    
    ARCHIVED --> [*] : End

# =============================================================================
# 2. HIERARCHICAL AGENT STRUCTURE
# =============================================================================

